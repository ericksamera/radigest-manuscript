# Python/cache/runtime noise
__pycache__/
*__pycache__
*.py[cod]
.ipynb_checkpoints/
.Rhistory
.RData
.Rproj.user/

# Snakemake internals
.snakemake/

# Local environment directories, if accidentally created inside repo
.conda/
env/
venv/
mamba/

# Raw immutable biological inputs.
# These are tracked by SHA256 in results/provenance/input_checksums.sha256,
# not by Git.
resources/references/**/*.fa
resources/references/**/*.fa.gz
resources/references/**/*.fasta
resources/references/**/*.fasta.gz
resources/references/**/*.fna
resources/references/**/*.fna.gz
resources/raw_reads/**/*.fq
resources/raw_reads/**/*.fq.gz
resources/raw_reads/**/*.fastq
resources/raw_reads/**/*.fastq.gz

# Reference indexes and mapping sidecars
resources/references/**/*.amb
resources/references/**/*.ann
resources/references/**/*.bwt
resources/references/**/*.pac
resources/references/**/*.sa
resources/references/**/*.fai
resources/references/**/*.dict
resources/references/**/*.gzi

# radigest build products regenerated by Snakemake
resources/software/radigest/bin/

# Large downstream generated analysis outputs.
# Scaffold provenance remains trackable below.
results/validation/**/*
results/screen/**/*
results/screening/**/*
results/observed/**/*
results/fit/**/*
results/calibration/**/*
results/compare/**/*
results/comparison/**/*
results/bench/**/*
results/benchmarking/**/*
results/logs/**/*

# Keep directory sentinels and scaffold provenance
!**/.gitkeep
!results/provenance/
!results/provenance/**

# Tables and figures are manuscript-facing outputs; keep them trackable by default.

# Bootstrap-only logs superseded by conda-lock.yml and final Snakemake provenance logs
results/provenance/environment.solve.dryrun.log
results/provenance/snakemake.forceall.log
results/provenance/snakemake.dryrun.after_forceall.log
results/provenance/snakemake.dryrun.after_vendor_patch.log
results/provenance/snakemake.dryrun.after_timestamp_patch.log
